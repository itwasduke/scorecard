  <circle cx="228" cy="410" r="5" fill="#ddd"/>
  <circle cx="244" cy="402" r="5" fill="#ddd"/>
  <circle cx="258" cy="412" r="5" fill="#ddd"/>
  <circle cx="226" cy="426" r="5" fill="#ddd"/>
